{
  "name": "claude-usage-sidebar",
  "displayName": "Claude Usage Sidebar",
  "description": "Shows cropped 'Current session' and 'Extra usage' sections from Claude usage page in a sidebar and refreshes on an interval.",
  "version": "1.0.3",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/Maaggel/VSCode-Claude-Usage-Sidebar"
  },
  "engines": {
    "vscode": "^1.108.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeUsageContainer",
          "title": "Claude",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudeUsageContainer": [
        {
          "id": "claudeUsage.view",
          "name": "Usage",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeUsage.refreshNow",
        "title": "Claude Usage: Refresh Now"
      },
      {
        "command": "claudeUsage.openUsagePage",
        "title": "Claude Usage: Open Usage Page"
      }
    ],
    "configuration": {
      "title": "Claude Usage Sidebar",
      "properties": {
        "claudeUsage.refreshSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 10,
          "description": "Refresh interval in seconds."
        },
        "claudeUsage.browserPath": {
          "type": "string",
          "default": "",
          "description": "Custom browser executable path (e.g., path to Chromium). Leave empty to use Chrome or system default."
        },
        "claudeUsage.dataBrowser": {
          "type": "string",
          "enum": ["auto", "chrome", "chromium", "edge", "brave", "vivaldi", "opera"],
          "default": "auto",
          "description": "Which browser's usage data to display. 'auto' shows the most recently updated data."
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.108.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.19.0",
    "vsce": "^2.15.0"
  }
}
